{
  "@context": {
    "@vocab": "https://etzhayyim.com/ns/actor#",
    "id": "@id",
    "type": "@type"
  },
  "id": "actor:hakoniwa",
  "type": "Actor",
  "name": "hakoniwa",
  "glyph": "箱庭",
  "purpose": "Forward-simulation observatory — the charter-clean inversion of a swarm-intelligence prediction engine (the 666ghj/MiroFish shape). Runs a CONTAINED miniature world (箱庭) of FICTIONAL latent personas forward in discrete steps to surface a DISTRIBUTION over possible futures, routed to resilience & preparedness; never a point prediction, never a real-person model, never a steering/persuasion campaign.",
  "status": "R1-live-operation-and-social-emission-authorized",
  "tier": "B",
  "adr": "2606111500",
  "dependsOnAdr": ["2606111400", "2606051800", "2606042330", "2606091200", "2605242600", "2605241900", "2605215000", "2605312345", "2605231525", "2605181100"],
  "schema": ["00-contracts/schemas/hakoniwa-scenario-ontology.kotoba.edn"],
  "substrate": {
    "state": "kotoba Datom log (ADR-2605312345) — methods/datom_emit.py emits canonical EAVT (ground world + run config; distribution is transient)",
    "engine": "methods/simulate.py — Friedkin-Johnsen opinion-dynamics kernel over the box; K-replica ensemble with DETERMINISTIC seeded anchor jitter (sha256, no Math.random, pywasm-portable)",
    "output": "methods/distribution.py — ensemble → quantiles + histogram → mitooshi-shaped :forecast/kind :distribution record (point-asserted structurally false)",
    "inference": "Murakumo-only (ADR-2605215000); the large-swarm LLM-persona step (when enabled) routes to the Murakumo fleet, the swarm rides baien-edge (ADR-2605242600/2605241900); R0 ships the deterministic kernel only",
    "contentAddress": "out artifacts content-addressable to a kotoba IPFS CIDv1 (same parity discipline as rasen methods/cid.py); reused, not re-implemented, at deploy time",
    "runtime": "kotoba pywasm actor (componentize-py) — pure-stdlib methods, no numpy; the deterministic kernel runs in-WASM, the LLM-persona variant runs operator/mesh-side"
  },
  "integrates": ["actor:mitooshi", "actor:sonae", "actor:kazaori", "actor:tsumugi", "actor:entity-as-actor"],
  "lineage": "forecasting sibling that FEEDS mitooshi 見通し (ADR-2606051800): mitooshi had a leak-free proper-scoring backtest loop but no generative simulation engine; hakoniwa is the generative front-end that produces the distributions mitooshi scores. Persona discipline borrowed from sukashi (synthesized fictional entities) + tsumugi (latent influence nodes). Resilience consumer = sonae 備え / kazaori 風折.",
  "cells": [
    {
      "id": "cell:hakoniwa.world",
      "method": "methods/world.py",
      "input": "data/seed-scenario.kotoba.edn",
      "output": ["(in-memory world graph)"],
      "pipeline": "load-edn → nodes (:persona/:entity/:signal/:outcome) + 縁 (:influences/:exposed-to/:holds-stance/:measures); assert_synthetic REFUSES any persona not marked :persona/synthetic true or carrying a PII-class field (G1)",
      "doc": "the contained miniature world (箱庭); synthetic personas only, enforced at load"
    },
    {
      "id": "cell:hakoniwa.simulate",
      "method": "methods/simulate.py",
      "input": "data/seed-scenario.kotoba.edn",
      "output": ["(replica ensemble of population statistics)"],
      "pipeline": "build topology (row-normalised :influences, susceptibility λ, anchors + signal pushes) → run K replicas of Friedkin-Johnsen forward dynamics with deterministic per-replica anchor jitter → collect the town-wide weighted-mean stance per replica",
      "doc": "deterministic multi-agent forward simulation; the ensemble spread IS the distribution (G2)"
    },
    {
      "id": "cell:hakoniwa.distribution",
      "method": "methods/distribution.py",
      "input": "data/seed-scenario.kotoba.edn",
      "output": ["out/distribution-report.md", "out/forecast-record.kotoba.edn"],
      "pipeline": "ensemble → quantiles (p10/p25/p50/p75/p90) + histogram + mean/stdev → mitooshi-shaped :forecast/kind :distribution record (:forecast/point-asserted false, :forecast/use :preparedness)",
      "doc": "DISTRIBUTION-ONLY readout (G2) handed to mitooshi for leak-free proper-scoring; resilience-USE-only enum (G3)"
    },
    {
      "id": "cell:hakoniwa.datom-emit",
      "method": "methods/datom_emit.py",
      "input": "data/seed-scenario.kotoba.edn",
      "output": ["out/scenario-datoms.kotoba.edn"],
      "pipeline": "ground EAVT datoms [e a v tx :add] for nodes/縁/run-config (every persona carries :persona/synthetic true) + derived distribution flagged :bond/is-transient; NO point datom (G2)",
      "doc": "kotoba Datom-log projection — first-class canonical state (ADR-2605312345)"
    },
    {
      "id": "cell:hakoniwa.murakumo",
      "method": "methods/murakumo.py",
      "input": "(distribution readout)",
      "output": ["(narration text + :via)"],
      "pipeline": "narrate a distribution into a one-paragraph human summary via the Murakumo loopback gateway (127.0.0.1:4000, gemma3:4b); GRACEFUL deterministic template fallback when the fleet is offline; persona_step = LLM-persona swarm variant with scalar-kernel fallback",
      "doc": "Murakumo-only (G5) — contacts ONLY the loopback gateway, never a commercial endpoint; never blocks the run",
      "gated": "G5 — all inference Murakumo-only (ADR-2605215000); swarm variant rides baien-edge"
    },
    {
      "id": "cell:hakoniwa.social",
      "method": "methods/social.py",
      "input": "(distribution + narration)",
      "output": ["(app.bsky.feed.post-shaped record)"],
      "pipeline": "draft a post narrating the DISTRIBUTION → _guard_no_point (G2) + _guard_no_steer (G3) re-applied at draft AND emit → emit to the canonical kotoba log (substrate of record); external AT-Proto relay via operator transport when present",
      "doc": "R1 social emission (founder-authorized). :post/status :published needs a member-DID author (G7 — member signs, never the server). Distribution-only + non-steering enforced at the emission boundary",
      "gated": "G7/G8 — :published needs member-DID author + signature; external firehose relay needs an operator transport credential (no server-held key)"
    },
    {
      "id": "cell:hakoniwa.kotoba",
      "method": "methods/kotoba.py",
      "input": "(box + distribution + posts)",
      "output": ["data/hakoniwa.datoms.kotoba.edn"],
      "pipeline": "flatten box/distribution/posts → content-addressed transaction (sha256 over datoms + prev CID → commit-DAG) → append-only write; read_log / head_cid / verify_chain (tamper-evident)",
      "doc": "append-only kotoba Datom log (非終末論); distribution persists as quantile datoms + :forecast/point-asserted false — NEVER a point datom (G2)"
    },
    {
      "id": "cell:hakoniwa.autorun",
      "method": "methods/autorun.py",
      "input": "data/seed-scenario.kotoba.edn",
      "output": ["data/hakoniwa.datoms.kotoba.edn"],
      "pipeline": "AUTONOMOUS heartbeat: load box → simulate (scalar kernel OR --swarm LLM-per-agent) → distribution → narrate (Murakumo/fallback) → draft+emit post → persist ONE content-addressed tx per cycle; deterministic + resume-safe (identical CIDs on re-run)",
      "doc": "kotoba で自律的に稼働 — the actor drives its own observe→simulate→emit→persist cycle over its own substrate (R1; live external firehose relay still operator-transport-gated)"
    },
    {
      "id": "cell:hakoniwa.ingest",
      "method": "methods/ingest.py",
      "input": "data/ingest-sources.edn",
      "output": ["out/ingested-box.kotoba.edn", "out/ingested-box.cid", "out/ingest-provenance.json"],
      "pipeline": "fetch a BOUNDED slice of REAL PUBLIC entities (Wikidata Special:EntityData, CC0) → G1 filter (DROP any P31=Q5 natural person) → fold orgs/topics in as :authoritative :entity nodes + :relates-to structural edges → generate SYNTHETIC personas (hash-seeded fictional archetypes) deliberating over the topic → emit box + content-address (CIDv1 raw, ipfs-parity)",
      "doc": "REAL-ENTITY INGEST (R1-authorized). Real entities are orgs/topics ONLY (persons refused, G1); the AGENTS stay synthetic. Runs operator/mesh-side (needs network), never in-browser WASM",
      "gated": "G8 — bounded public slice runs freely; SCOPE EXPANSION (more QIDs/sources) needs Council + operator DID; natural-person ingest is unrepresentable (G1)"
    },
    {
      "id": "cell:hakoniwa.cid",
      "method": "methods/cid.py",
      "input": "(any artifact bytes)",
      "output": ["(kotoba IPFS CIDv1 raw/sha2-256)"],
      "pipeline": "CIDv1 / raw (0x55) / sha2-256 / base32-'b' — byte-identical to `ipfs add --cid-version=1 --raw-leaves`; verifiable with no daemon (ADR-2605231525 / 2606014500 verify.mjs parity)",
      "doc": "content-address an ingested box; reused, not re-implemented"
    }
  ],
  "gates": {
    "G1": "FICTIONAL latent personas only, NEVER a real-person model — every :persona is :persona/synthetic true (a cohort archetype), with NO PII / no real-person profile / no re-identifiable trait; world.assert_synthetic refuses a graph that breaches this. Real already-PUBLIC entities (entity-as-actor org.* / a public topic / a Wikidata org/topic) may appear as their existing public mirror, never a natural person — methods/ingest.py DROPS any fetched entity whose P31 instance-of is a natural-person class (Q5 …), so the ingest can never store a person. Simulating fictional agents is categorically distinct from surveilling real people (ADR-2606111400)",
    "G2": "DISTRIBUTION-ONLY (inherits mitooshi ADR-2606051800 G1) — output is a distribution over outcomes (quantiles + histogram), never a point; :forecast/point-asserted is structurally false and no :forecast/point field exists. 非終末論 made structural",
    "G3": "NON-STEERING (inherits mitooshi G2) — routed to resilience / preparedness / robustness; :forecast/use and :outcome/use are a resilience-only enum; trade / wager / position / target / manipulate / campaign are NOT members and are unrepresentable. hakoniwa never trades, never targets a person, never runs an influence campaign",
    "G4": "TRANSPARENT & RECIPROCAL (相互監視; ADR-2606082400 + 2606111400) — the whole box (world graph, persona parameters, every step, the run config) is plaintext-public on kotoba; open-source + on-chain + 1 SBT = 1 vote. No covert/asymmetric modelling — there are no real people in the box",
    "G5": "Murakumo-only inference (ADR-2605215000) for the LLM-persona variant; the swarm rides baien-edge (ADR-2605242600/2605241900)",
    "G6": "sourcing honesty — personas :synthetic, real public facts :authoritative | :representative; coverage honesty preserved (a box is illustrative, never exhaustive of a real population)",
    "G7": "leak-free as-of (inherits mitooshi G5) — the forecast record carries :forecast/as-of; no future information leaks into the persona priors; mitooshi scores it leak-free with proper scoring",
    "G8": "outward gate — R1 (founder-authorized, Council Lv7+ 1/1, 2026-06-11): hakoniwa runs AUTONOMOUSLY, SOCIAL EMISSION is AUTHORIZED, REAL-PUBLIC-ENTITY INGEST is AUTHORIZED (methods/ingest.py — bounded Wikidata orgs/topics, persons refused by G1), and the LIVE LLM-PERSONA SWARM is AUTHORIZED (methods/simulate.py swarm_ensemble + murakumo.persona_step, Murakumo + baien-edge, kernel fallback). Emission persists to the canonical kotoba Datom log (substrate of record); the EXTERNAL AT-Proto firehose relay is a downstream projection needing an operator transport credential (no-server-key, G7). STILL gated: SCOPE EXPANSION of the bounded ingest slice (more QIDs/sources → Council + operator DID). Real-person modelling is unrepresentable regardless of gate state (G1 / ADR-2606111400 hard line)"
  }
}
